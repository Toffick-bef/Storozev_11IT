print("="*29)
status = input("Введите статус заказа:")
match status:
    case "pending"|"в ожидании":
        print("💱💱💱 Статус: в ожидании 💱💱💱\nОписание: Ожидает оплаты\nПримерное время ожидания: 1 час\nРекомендации: Оплатите заказ")
    case "processing"|"в обработке":
        print("🕐🕑🕒 Статус: в обработке 🕐🕑🕒\nОписание: Ожидает подтверждения\nПримерное время ожидания: 1 час\nРекомендации: Ожидайте подтверждения")
    case "shipped"|"отправлено":
        print("️✈️✈️️✈️ Статус: отправлено ️✈️✈️️✈️\nОписание: Ваш заказ в пути\nПримерное время ожидания: 2-5 дней\nРекомендации: Следите за уведомлениями о доставке")
    case "delivered"|"доставлено":
        print("📦📦📦 Статус: доставлено 📦📦📦\nОписание: Ваш заказ в пункте выдачи\nПримерное время ожидания: 0 дней\nРекомендации: Заберите заказ")
    case "cancelled"|"отменён":
        print("❌❌❌ Статус: отменён ❌❌❌\nОписание: Ваш заказ отменён")
    case _:
        print("Статус: Неизвестный\nДоступные статусы: pending, processing, shipped, delivered, cancelled\nИли: в ожидании, в обработке, отправлено, доставлено, отменён")
