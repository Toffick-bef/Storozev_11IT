Задание№1
print("Система рейтинга продуктов")
r = int(input("Введите рейтинг продукта(от 1 до 10):"))
match r:
    case 1| 2| 3:
        print("❌❌❌ Плохой продукт! Ну прям БЕЕЕЕЕЕ! Не рекомендую! ❌❌❌")
    case 4| 5| 6:
        print("🤔🤔🤔 Средний продукт  Можно рискнуть 🤔🤔🤔")
    case 7| 8:
        print("👍👍👍 Хороший продукт! Рекомендуется! 👍👍👍")
    case 9| 10:
        print("💯💯💯 Замечательный продукт!🌟 Бери, Бери, Не пожалеешь! 💯💯💯")
    case _:
        print("❌Неверный параметр оценки рейтинга❌")

