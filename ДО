class Block:
    def __init__(self, name = None, hardness = 0, breakable = False):
        self.name = name
        self.hardness = hardness
        self.breakable = breakable

    def show_info(self):
        print(f"Блок: {self.name}, \nПрочность: {self.hardness}, \nМожно сломать: {self.breakable}, \n   ")


class Stone(Block):
    def set_properties(self, name = "Stone", hardness = 10, breakable = "Можно сломать"):
        self.name = name
        self.hardness = hardness
        self.breakable = breakable


class Bedrock(Block):
    def set_properties(self, name = "Bedrock", hardness = 999, breakable = "Нельзя сломать"):
        self.name = name
        self.hardness = hardness
        self.breakable = breakable


class GrassBlock(Block):
    def set_properties(self, name = "GrassBlock", hardness = 1, breakable = "Можно сломать"):
        self.name = name
        self.hardness = hardness
        self.breakable = breakable


stone = Stone()
bedrock = Bedrock()
grass = GrassBlock()

stone.set_properties()
bedrock.set_properties()
grass.set_properties()

stone.show_info()
bedrock.show_info()
grass.show_info()
